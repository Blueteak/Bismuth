{
  "name": "bismuth-visualizer",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=24.12.0 <25"
  },
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "test:gpu": "node scripts/run-browser-gpu-test.mjs",
    "test:e2e": "playwright test",
    "benchmark": "node scripts/run-browser-gpu-test.mjs --benchmark",
    "validate:morphology:quick": "node scripts/run-browser-gpu-test.mjs --morphology --profile=hopper-quick --perturbed --expected=hopper --operator=conservative-flux --domain=full --high-resolution --grid=128 --spacing=2 --steps=50000 --dt=0.01 --dl=0.08333333333333333 --mu=0.04 --surface-scale=0.3203895937459951 --max-wall-ms=25000",
    "validate:morphology:reference": "node scripts/run-browser-gpu-test.mjs --morphology --profile=hopper-reference --perturbed --expected=hopper --operator=conservative-flux --domain=full --high-resolution --grid=256 --spacing=1 --steps=50000 --dt=0.01 --dl=0.08333333333333333 --mu=0.04 --surface-scale=0.3203895937459951",
    "validate:morphology": "node scripts/run-browser-gpu-test.mjs --morphology --profile=hopper-acceptance --baseline --expected=hopper --operator=conservative-flux --domain=full --high-resolution --grid=256 --spacing=1 --steps=50000 --dt=0.01 --dl=0.08333333333333333 --mu=0.04 --surface-scale=0.3203895937459951",
    "validate:morphology:seed:99539473": "node scripts/run-browser-gpu-test.mjs --morphology --perturbed --seed=99539473 --expected=hopper --operator=conservative-flux --domain=full --high-resolution --grid=128 --spacing=2 --steps=50000 --dt=0.01 --dl=0.08333333333333333 --mu=0.04 --surface-scale=0.3203895937459951 --max-wall-ms=25000",
    "validate:morphology:seed:324508639": "node scripts/run-browser-gpu-test.mjs --morphology --perturbed --seed=324508639 --expected=hopper --operator=conservative-flux --domain=full --high-resolution --grid=128 --spacing=2 --steps=50000 --dt=0.01 --dl=0.08333333333333333 --mu=0.04 --surface-scale=0.3203895937459951 --max-wall-ms=25000",
    "validate:morphology:seed:610839776": "node scripts/run-browser-gpu-test.mjs --morphology --perturbed --seed=610839776 --expected=hopper --operator=conservative-flux --domain=full --high-resolution --grid=128 --spacing=2 --steps=50000 --dt=0.01 --dl=0.08333333333333333 --mu=0.04 --surface-scale=0.3203895937459951 --max-wall-ms=25000",
    "validate:morphology:seed:3221344269": "node scripts/run-browser-gpu-test.mjs --morphology --perturbed --seed=3221344269 --expected=hopper --operator=conservative-flux --domain=full --high-resolution --grid=128 --spacing=2 --steps=50000 --dt=0.01 --dl=0.08333333333333333 --mu=0.04 --surface-scale=0.3203895937459951 --max-wall-ms=25000",
    "validate:morphology:seeds:compare": "node scripts/compare-hopper-seed-results.mjs",
    "validate:transition:fractal": "node scripts/run-browser-gpu-test.mjs --morphology --baseline --expected=fractal --operator=conservative-flux --domain=full --high-resolution --grid=256 --spacing=2 --steps=50000 --dt=0.01 --dl=0.5 --mu=0.04 --surface-scale=0.3203895937459951",
    "validate:transition:cube": "node scripts/run-browser-gpu-test.mjs --morphology --baseline --expected=cube --operator=conservative-flux --domain=full --high-resolution --grid=256 --spacing=2 --steps=100000 --dt=0.005 --dl=20 --mu=0.04 --surface-scale=0.3203895937459951",
    "validate:transition:fractal:source": "node scripts/run-browser-gpu-test.mjs --morphology --baseline --expected=fractal --operator=author-centered --domain=full --high-resolution --grid=256 --spacing=2 --steps=50000 --dt=0.01 --dl=0.5 --mu=0.04 --surface-scale=0.3203895937459951",
    "validate:transition:cube:source": "node scripts/run-browser-gpu-test.mjs --morphology --baseline --expected=cube --operator=author-centered --domain=full --high-resolution --grid=256 --spacing=2 --steps=100000 --dt=0.005 --dl=20 --mu=0.04 --surface-scale=0.3203895937459951",
    "validate:transition:summarize": "node scripts/summarize-step1-transition-suite.mjs",
    "validate:transition:control": "node scripts/run-browser-gpu-test.mjs --morphology --profile=dl4-screen-control --baseline --expected=dendritic --operator=author-centered --domain=octant --high-resolution --grid=128 --spacing=2 --steps=35000 --dt=0.01 --dl=4 --mu=0.04 --surface-scale=0.3203895937459951 --max-wall-ms=25000",
    "validate:transition:quick": "node scripts/run-browser-gpu-test.mjs --morphology --profile=dl4-screen-quick --baseline --expected=dendritic --operator=author-centered --domain=octant --high-resolution --grid=128 --spacing=2 --steps=70000 --dt=0.005 --dl=4 --mu=0.04 --surface-scale=0.3203895937459951 --max-wall-ms=25000",
    "validate:transition:reference": "node scripts/run-browser-gpu-test.mjs --morphology --profile=dl4-screen-reference --baseline --expected=dendritic --operator=author-centered --domain=octant --high-resolution --grid=256 --spacing=1 --steps=70000 --dt=0.005 --dl=4 --mu=0.04 --surface-scale=0.3203895937459951",
    "validate:transition:compare": "node scripts/compare-dl4-screen-results.mjs",
    "validate:coupling": "node scripts/run-cpu-coupling-experiment.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist-server/index.js"
  },
  "dependencies": {
    "express": "5.2.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.185.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/express": "5.0.6",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.0",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
